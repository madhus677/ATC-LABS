#include <stdio.h>
#include <string.h>
#include <ctype.h>

char *keywords[] = {"int","float","if","else","while","return","for","char","double","void"};

int isKeyword(char *word){
    for(int i=0;i<10;i++)
        if(strcmp(word,keywords[i])==0)
            return 1;
    return 0;
}

int main(){
    char str[100], token[50];
    int i=0,j=0;

    printf("Enter C statement:\n");
    fgets(str,100,stdin);

    while(str[i]!='\0'){
        if(isalnum(str[i])){
            token[j++]=str[i];
        }
        else{
            if(j!=0){
                token[j]='\0';
                if(isKeyword(token))
                    printf("%s -> Keyword\n",token);
                else if(isdigit(token[0]))
                    printf("%s -> Number\n",token);
                else
                    printf("%s -> Identifier\n",token);
                j=0;
            }
            if(str[i]=='+'||str[i]=='-'||str[i]=='*'||str[i]=='/'||str[i]=='=')
                printf("%c -> Operator\n",str[i]);
        }
        i++;
    }
}
