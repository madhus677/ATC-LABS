#include <stdio.h>
#include <ctype.h>

int main(){
    char str[500];
    int lines=0, words=0, chars=0, i=0;

    printf("Enter text:\n");
    fgets(str,500,stdin);

    while(str[i]!='\0'){
        chars++;

        if(str[i]=='\n')
            lines++;

        if((str[i]==' '||str[i]=='\n'||str[i]=='\t') && isalpha(str[i+1]))
            words++;

        i++;
    }

    printf("Lines: %d\nWords: %d\nCharacters: %d\n",lines,words+1,chars);
}
